# Supabase (público - exposto ao browser)
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# E-mail via AWS SES (server-side apenas - sem NEXT_PUBLIC_)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
ADMIN_EMAIL=your@email.com
SES_CONFIG_SET=my-first-configuration-set

# Opcional: manter ses-server externo em vez de usar /api/contact
# SES_ENDPOINT=https://seu-ses-server.com/api/send-email
