VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_GA_ID=G-XXXXXXXXXX

# Relay de e-mail (pasta ses-server) — origens permitidas (CORS), vírgula
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Limite de pedidos / IP / hora no endpoint de envio (opcional)
RATE_LIMIT_MAX=5
# Confia no 1º proxy (ex.: reverse proxy) para rate limit por IP
TRUST_PROXY=1

# Se o relay estiver noutro domínio que o site, acrescenta esse URL em
# vercel.json > Content-Security-Policy > connect-src para o formulário funcionar.
